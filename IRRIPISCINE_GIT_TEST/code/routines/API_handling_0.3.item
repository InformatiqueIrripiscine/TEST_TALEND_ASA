/*
 * user specification: the function's comment should contain keys as follows: 1. write about the function's comment.but
 * it must be before the "{talendTypes}" key.
 * 
 * 2. {talendTypes} 's value must be talend Type, it is required . its value should be one of: String, char | Character,
 * long | Long, int | Integer, boolean | Boolean, byte | Byte, Date, double | Double, float | Float, Object, short |
 * Short
 * 
 * 3. {Category} define a category for the Function. it is required. its value is user-defined .
 * 
 * 4. {param} 's format is: {param} <type>[(<default value or closed list values>)] <name>[ : <comment>]
 * 
 * <type> 's value should be one of: string, int, list, double, object, boolean, long, char, date. <name>'s value is the
 * Function's parameter name. the {param} is optional. so if you the Function without the parameters. the {param} don't
 * added. you can have many parameters for the Function.
 * 
 * 5. {example} gives a example for the Function. it is optional.
 */
public class API_handling {
	
	public static String streamToString(InputStream inputStream) {
        @SuppressWarnings("resource")
		String text = new Scanner(inputStream, "UTF-8").useDelimiter("\\Z").next();
        return text;
      }
	  
	  /**
       * callApi: Call Api.
       * 
       * 
       * {talendTypes} String
       * 
       * {Category} API_handling
       * 
       * {param} string(urlQueryString) input: The string need to be printed.
       * {param} string(fileDir) input: The string need to be printed.
       * {param} string(fileName) input: The string need to be printed.
       * {param} string(fileExt) input: The string need to be printed.
       * {param} string(token) input: The string need to be printed.
       * {param} string(numPage) input: The string need to be printed.
       * 
       * {example} callApi(urlQueryString, fileDir, fileName, fileExt, token, numPage).
       */
    	
    	private static String callApi(String urlQueryString, String fileDir, String fileName,
    			String fileExt, String token, int numPage) throws JSONException, IOException {
  		
    		String result = "";
      		String jsonErr = "";
	        String json = null;
	        URL url = new URL(urlQueryString);
	        //System.out.println("urlQueryString : "+urlQueryString);
	        HttpURLConnection connection = (HttpURLConnection) url.openConnection();
		    
	        try {
	          connection.setDoOutput(true);
	          connection.setInstanceFollowRedirects(false);
	          connection.setRequestMethod("GET");
	          connection.setRequestProperty("Content-Type", "application/json;charset=UTF-8");
	          connection.setRequestProperty("Authorization", token);
	          connection.connect();
	          InputStream inStream = connection.getInputStream();
	          json = streamToString(inStream);
	        } catch (IOException ex) {
	          //ex.printStackTrace();
	          InputStream inStream = connection.getErrorStream();
  	          jsonErr = streamToString(inStream);
  	          //System.out.println("jsonErr : "+jsonErr);
	        }
	        
	        result = JSON_handling.JsonFormatter(json, 4);
	        writeFile(JSON_handling.JsonFormatter(result, 4), fileDir, fileName+numPage+fileExt);
	        return result;
	        
    }
    	
      	/**
         * writeFile: write request in a new file.
         * 
         * 
         * {talendTypes} String
         * 
         * {Category} API_handling
         * 
         * {param} string(JsonStr) input: The string need to be printed.
         * {param} string(fileDir) input: The string need to be printed.
         * {param} string(fileName) input: The string need to be printed.
         * 
         * {example} writeFile(JsonStr, fileDir, fileName).
         */
      	
    	public static void writeFile(String JsonStr, String fileDir, String fileName) throws IOException {
      		
    		if (JsonStr != null && !JsonStr.trim().equals(""))
    		{
	    		File fPath = new File(fileDir);
	    		
	    			if (!fPath.exists())
	    			{
	    				fPath.mkdir();
	    	        }    
	    		
	    		//BufferedWriter writer = new BufferedWriter(new FileWriter(fileDir+fileName));
	    			
	    		//UTF-8
	    		Writer out = new BufferedWriter(new OutputStreamWriter(new FileOutputStream(fileDir+fileName), "UTF-8"));
	    			    out.write(xmlEntitify(JsonStr));
	    			    out.close();

	    		
	      		    
	      		    //writer.write(JsonStr);
	      		    //System.out.println("Write Json : " + fileDir+fileName);
	      		     
	      		    //writer.close();
    		}
    		
    		else System.out.println("There is no data to write");
      	}
	  
	  /**
       * ApiRequestAllPages: Retrieve all pages for one call.
       * 
       * 
       * {talendTypes} String
       * 
       * {Category} API_handling
       * 
       * {param} string(urlQueryString) input: The string need to be printed.
       * {param} string(fileDir) input: The string need to be printed.
       * {param} string(fileName) input: The string need to be printed.
       * {param} string(fileExt) input: The string need to be printed.
       * {param} string(token) input: The string need to be printed.
       * 
       * {example} ApiRequestAllPages(urlQueryString, fileDir, fileName, fileExt, token).
       */
    	
    	public static void ApiRequestAllPages(String urlQueryString, String fileDir, String fileName,
    			String fileExt, String token) throws JSONException, IOException {
  		
  		String result = "";
  		int numPage = 1;
		    
	        result = callApi(urlQueryString, fileDir, fileName,fileExt, token, numPage);
	        
	        while (result.contains("\"next\""))
	        	{
	        		numPage = numPage +1;
	        		String NewUrl = result.split("\"next\"")[1].split("\"},")[0].replace(": {\"href\": \"", "");
	        				//.replace("page&limit=10", "page&limit=30");
	        		//System.out.println("NewUrl : " + NewUrl);
	        		result = callApi(NewUrl, fileDir, fileName,fileExt, token, numPage);
	        	}
	   }
    	
        /**
         * postApi: Post API, to create new data.
         * 
         * 
         * {talendTypes} String
         * 
         * {Category} API_handling
         * 
         * {param} string(urlQueryString) input: The string need to be printed.
         * {param} string(jsonInputString) input: The string need to be printed.
         * {param} string(token) input: The string need to be printed.
         * 
         * {example} postApi(urlQueryString, jsonInputString, token).
         * 
         * @throws IOException 
         */
        public static String postApi(String urlQueryString, String jsonInputString, String token) 
        		throws IOException {
        	
        	String jsonErr = "";
        	URL url = new URL (urlQueryString);
        	HttpURLConnection con = (HttpURLConnection)url.openConnection();
        	con.setRequestMethod("POST");
        	con.setRequestProperty("Content-Type", "application/json;charset=UTF-8");
        	con.setRequestProperty("Accept", "application/json");
        	con.setRequestProperty("Authorization", token);
        	con.setDoOutput(true);
        	
        	try(OutputStream os = con.getOutputStream()) {
        	    byte[] input = jsonInputString.getBytes("utf-8");
        	    os.write(input, 0, input.length);           
        	}
        	
        	try(BufferedReader br = new BufferedReader(
        			  new InputStreamReader(con.getInputStream(), "utf-8"))) {
        			    StringBuilder response = new StringBuilder();
        			    String responseLine = null;
        			    while ((responseLine = br.readLine()) != null) {
        			        response.append(responseLine.trim());
        			    }
        			    
        			}
        	catch (IOException ex) {
  	          //ex.printStackTrace();
  	          InputStream inStream = con.getErrorStream();
  	          jsonErr = streamToString(inStream);
  	        }
        	jsonErr = JSON_handling.JsonFormatter(jsonErr, 4);
        	return jsonErr;

        }
        
        /**
         * getApi: Get API, to verify data.
         * 
         * 
         * {talendTypes} String
         * 
         * {Category} API_handling
         * 
         * {param} string(urlQueryString) input: The string need to be printed.
         * {param} string(token) input: The string need to be printed.
         * 
         * {example} getApi(urlQueryString, token).
         * 
         * @throws IOException 
         */
        public static String getApi(String urlQueryString, String token) 
        		throws IOException {
        	
	        String json = "";
	        URL url = new URL(urlQueryString);
	        HttpURLConnection connection = (HttpURLConnection) url.openConnection();
		    
	        try {
	          connection.setDoOutput(true);
	          connection.setInstanceFollowRedirects(false);
	          connection.setRequestMethod("GET");
	          connection.setRequestProperty("Content-Type", "application/json;charset=UTF-8");
	          connection.setRequestProperty("Authorization", token);
	          connection.connect();
	          InputStream inStream = connection.getInputStream();
	          json = streamToString(inStream);
	        } catch (IOException ex) {
	          //ex.printStackTrace();
	          InputStream inStream = connection.getErrorStream();
	          json = streamToString(inStream);
	        }
        	
        	return json;

        }
        
