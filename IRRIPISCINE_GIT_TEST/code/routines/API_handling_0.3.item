        /**
         * patchApi: Post API, to update data.
         * 
         * 
         * {talendTypes} String
         * 
         * {Category} API_handling
         * 
         * {param} string(urlQueryString) input: The string need to be printed.
         * {param} string(jsonInputString) input: The string need to be printed.
         * {param} string(token) input: The string need to be printed.
         * 
         * {example} patchApi(urlQueryString, jsonInputString, token).
         * 
         * @throws IOException 
         */
        public static String patchApi(String urlQueryString, String jsonInputString, String token) 
        		throws IOException {
        	
        	String jsonErr = "";
        	URL url = new URL (urlQueryString);
        	HttpURLConnection con = (HttpURLConnection)url.openConnection();
        	con.setRequestProperty("X-HTTP-Method-Override", "PATCH");
        	con.setRequestMethod("POST");
        	con.setRequestProperty("Content-Type", "application/json;charset=UTF-8");
        	con.setRequestProperty("Accept", "application/json");
        	con.setRequestProperty("Authorization", token);
        	con.setDoOutput(true);
        	
        	try(OutputStream os = con.getOutputStream()) {
        	    byte[] input = jsonInputString.getBytes("utf-8");
        	    os.write(input, 0, input.length);           
        	}
        	
        	try(BufferedReader br = new BufferedReader(
        			  new InputStreamReader(con.getInputStream(), "utf-8"))) {
        			    StringBuilder response = new StringBuilder();
        			    String responseLine = null;
        			    while ((responseLine = br.readLine()) != null) {
        			        response.append(responseLine.trim());
        			    }
        			    
        			}
        	catch (IOException ex) {
  	          //ex.printStackTrace();
  	          InputStream inStream = con.getErrorStream();
  	          jsonErr = streamToString(inStream);
  	        }
        	//jsonErr = JSON_handling.JsonFormatter(jsonErr, 4);
        	return jsonErr;

        }
        
        /**
         * xmlEntitify: Remove strange character from XML format.
         * 
         * 
         * {talendTypes} String
         * 
         * {Category} API_handling
         * 
         * {param} string(in) input: The string need to be printed.
         * 
         * {example} xmlEntitify(in).
         * 
         * @throws IOException 
         */
        public static String xmlEntitify(String in){

            StringBuffer b = new StringBuffer();

            for (int i=0;i<in.length();i++){

                Character c = in.charAt(i);
                if (c<128){
                    b.append(c);
                }
                else if (c=='\ufeff'){
                    // BOM character, just remove it
                }
                else {
                    String cstr = Integer.toHexString(c).toUpperCase();
                    while(cstr.length()<4){
                        cstr="0"+cstr;
                    }
                    b.append("&#x");
                    b.append(cstr);
                    b.append(";");
                }
            }
            return b.toString();
        }
        /**
         * PatchProductApi: Post API, to create new data.
         * 
         * 
         * {talendTypes} String
         * 
         * {Category} API_handling
         * 
         * {param} string(urlQueryString) input: The string need to be printed.
         * {param} string(jsonInputString) input: The string need to be printed.
         * {param} string(token) input: The string need to be printed.
         * 
         * {example} postApi(urlQueryString, jsonInputString, token).
         * 
         * @throws IOException 
         */
        public static String PatchProductApi(String urlQueryString, String jsonInputString, String token) 
        		throws IOException {
        	
        	String jsonErr = "";
        	String jsonOK = "";
        	URL url = new URL(urlQueryString);
        	HttpURLConnection con = (HttpURLConnection) url.openConnection();
        	con.setRequestMethod("POST"); // Utilisez POST
        	con.setRequestProperty("X-HTTP-Method-Override", "PATCH"); // En-tête spécial pour indiquer PATCH
        	con.setRequestProperty("Content-Type", "application/vnd.akeneo.collection+json;charset=UTF-8");
        	con.setRequestProperty("Accept", "application/json");
        	con.setRequestProperty("Authorization", token);
        	con.setDoOutput(true); // Permet d'envoyer des données dans la requête

        	// Envoyer les données dans la requête
        	try (OutputStream os = con.getOutputStream()) {
        	    byte[] input = jsonInputString.getBytes("utf-8");
        	    os.write(input, 0, input.length);           
        	}

        	// Lire la réponse de l'API
        	try (BufferedReader br = new BufferedReader(
        	        new InputStreamReader(con.getInputStream(), "utf-8"))) {
        	    StringBuilder response = new StringBuilder();
        	    String responseLine = null;
        	    while ((responseLine = br.readLine()) != null) {
        	        response.append(responseLine.trim());
        	    }
        	    
        	    // Afficher la réponse
        	    //System.out.println("Réponse de l'API : " + response.toString());
        	    jsonOK = response.toString();
        	    
        	}

        	catch (IOException ex) {
  	          //ex.printStackTrace();
  	          InputStream inStream = con.getErrorStream();
  	          jsonErr = streamToString(inStream);
  	        
  	        }
        	jsonErr = JSON_handling.JsonFormatter(jsonErr, 4);
        	//System.out.println("Réponse de l'API : " +  jsonErr);

        		return "RETOURAPIOK"+jsonOK + "SEPARATEUR_REPONSE" +"RETOURAPIKO"+ jsonErr;


        }
        
        /**
         * streanToString: Remove strange character from XML format.
         * 
         * 
         * {talendTypes} String
         * 
         * {Category} API_handling
         * 
         * {param} string(inStream) input: The string need to be printed.
         * 
         * {example} streanToString(inStream).
         * 
         * @throws IOException 
         */
        
        public static InputStream streanToString(String inStream) 
        		  throws IOException {
        		    InputStream targetStream = new ByteArrayInputStream(inStream.getBytes());
        		    return targetStream;
        		}
      	
}
