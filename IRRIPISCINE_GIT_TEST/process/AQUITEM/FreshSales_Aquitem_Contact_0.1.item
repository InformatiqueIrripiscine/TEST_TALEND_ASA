    <elementParameter field="MEMO_JAVA" name="CODE" value="//CALCUL DU TOKEN&#xA;&#xA;//Récupération de l'ensemble des paramètres et valeurs passées dans le WebService hormis le Token + Concaténation avec la chaine mdp&#xA;&#xA;String WSPARAM_MDP = &quot;CONTEXTE=CAISSE&amp;IDSITE=001&amp;IDMAGASIN=VAD&amp;EMAIL=&quot;+((String)globalMap.get(&quot;row14.EMAIL&quot;))+&quot;&amp;IDCRM=&quot;+((String)globalMap.get(&quot;row14.IDCRM&quot;))+&quot;mdp=&quot;+context.Aquitem_API_mdp;&#xA;&#xA;//HASHAGE de ka chaine de caractère obtenue en MD5 (utilisation d'une routine)&#xA;String MD5WSPARAM_MDP = MD5Hash.hashMD5(WSPARAM_MDP);&#xA;&#xA;//Récupération du token à partir de la valeur Hashée en MD5 &#xA;String TOKEN = MD5WSPARAM_MDP.substring(9,19);&#xA;&#xA;//Enregistrement de la valeur en variable globale ( MAJ à chaque itération)&#xA;globalMap.put(&quot;AQUITEM_TOKEN&quot;, TOKEN);"/>
    <elementParameter field="MEMO_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="LABEL" value="__UNIQUE_NAME__&lt;br>&lt;b>Calcul token&lt;/b>"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJava_4"/>
  </node>
