        <mapperTableEntries name="message" expression="row13.S_STA.equals(&quot;0&quot;) ?&#xD;&#xA;&quot;Bonjour,&quot; +&quot;\n&quot;+&#xD;&#xA;&quot;Les écritures de chèques fidélité Comarch du &quot; + TalendDate.formatDate(&quot;dd/MM/yyyy&quot;, Var.Min_Date_Ecriture_to_use) + &quot; au &quot; + TalendDate.formatDate(&quot;dd/MM/yyyy&quot;, ((Date)globalMap.get(&quot;Max_Date_Ecriture&quot;))) + &quot; ont été intégrées dans X3 aujourd\'hui.&quot; +&quot;\n&quot;+&#xA;&quot;Voici, le SAS X3 associé : &quot; + row13.S_RETMSG.replaceAll(&quot;Ã©&quot;, &quot;é&quot;).replaceAll(&quot;Ã¨&quot;, &quot;è&quot;).replace(&quot;0:Intégration du fichier ok &quot;, &quot;&quot;)&#xD;&#xA;:&#xD;&#xA;&quot;Bonjour,&quot; +&quot;\n&quot;+&#xD;&#xA;&quot;Le fichier Comarch avec les chèques fidélités du &quot; +TalendDate.formatDate(&quot;dd/MM/yyyy&quot;, Var.Min_Date_Ecriture_to_use) + &quot; au &quot; + TalendDate.formatDate(&quot;dd/MM/yyyy&quot;, ((Date)globalMap.get(&quot;Max_Date_Ecriture&quot;)))+ &quot; a été intégré. Il y a une ou plusieurs erreurs.&quot; +&quot;\n&quot;+&#xA;&quot;Consultez le SAS YPROGAS pour faire l\'import des écritures en erreurs.&quot; +&quot;\n&quot;+&#xA;&quot;Voici, le SAS X3 à consulter : &quot; + row13.S_RETMSG.replaceAll(&quot;Ã©&quot;, &quot;é&quot;).replaceAll(&quot;Ã¨&quot;, &quot;è&quot;).replace(&quot;5:Sas non soldé - problème rencontré &quot;, &quot;&quot;) " type="id_String" nullable="true"/>
