        <mapperTableEntries name="Last_Ecriture_Date_plus_1" expression="TalendDate.addDate(((Date)globalMap.get(&quot;Last_Ecriture_Date&quot;)) ,1,&quot;dd&quot;) " type="id_Date"/>
