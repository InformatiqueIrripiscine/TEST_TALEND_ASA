        <mapperTableEntries name="line" expression="//if customers&#xD;&#xA;((String)globalMap.get(&quot;tFileList_4_CURRENT_FILE&quot;)).contains(&quot;client&quot;) ?&#xA;//if 8 carac is not a letter replace compteur num&#xD;&#xA;out1.IsNotLetter ==true  ? out1.line.replace(out1.line.substring(out1.indexDebut,out1.indexFin), out1.Compteur_NUM_to_use) :&#xD;&#xA;out1.line :&#xD;&#xA;&#xD;&#xA;// if commande projet&#xD;&#xA;((String)globalMap.get(&quot;tFileList_4_CURRENT_FILE&quot;)).contains(&quot;vcs&quot;) ?&#xA;//if 8 carac is not a letter replace compteur num&#xD;&#xA;out1.line.contains(&quot;CDE&quot;) &amp;&amp; out1.IsNotLetter ==true  ?  &#xD;&#xA;out1.line.replace(out1.line.substring(out1.indexDebut,out1.indexFin), out1.Compteur_NUM_to_use) :&#xA;//if 8 carac is a letter replace compteur num&#xD;&#xA;out1.line.contains(&quot;ADRS&quot;) &amp;&amp; out1.IsNotLetter ==true  ? &#xD;&#xA;out1.line.replace(out1.line.substring(out1.indexDebut,out1.indexFin), out1.Compteur_NUM_to_use) :&#xD;&#xA;out1.line:&#xD;&#xA;// if Ventes&#xA;((String)globalMap.get(&quot;tFileList_4_CURRENT_FILE&quot;)).contains(&quot;autre&quot;) ?&#xD;&#xA;out1.line.contains(&quot;APPMVT&quot;) &amp;&amp; out1.IsNotLetter ==true ? &#xA;//if 8 carac is not a letter replace compteur num&#xD;&#xA;out1.line.replace(out1.line.substring(out1.indexDebut,out1.indexFin), out1.Compteur_NUM_to_use):&#xA;//if 8 carac is not a letter replace compteur num&#xA;out1.line.contains(&quot;MVTFINAN&quot;) &amp;&amp; out1.IsNotLetter ==true ? &#xA;out1.line.replace(out1.line.substring(out1.indexDebut,out1.indexFin), out1.Compteur_NUM_to_use) : out1.line &#xD;&#xA;: out1.line " type="id_String"/>
