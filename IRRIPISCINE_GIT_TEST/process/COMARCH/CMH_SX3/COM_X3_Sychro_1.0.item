        <mapperTableEntries name="Col_48_TVA" expression="//StringHandling.EREPLACE(row38.line,&quot;^(?:[^|]*\\|){48}([^|]*)\\|(.*)$&quot;,&quot;$1&quot;) &#xD;&#xA;ExtractString.BetweenPipes(row38.line,49) " type="id_String"/>
