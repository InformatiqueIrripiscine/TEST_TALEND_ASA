        <mapperTableEntries name="Number8ofcompteur_num" expression="Var.Number8ofcompteur_num " type="id_String"/>
        <mapperTableEntries name="IsNotLetter" expression="Var.IsNotLetter " type="id_Boolean" nullable="true"/>
        <mapperTableEntries name="Compteur_NUM_to_use" expression="Var.Compteur_NUM_to_use " type="id_String"/>
        <mapperTableEntries name="indexDebut" expression="Var.indexDebut " type="id_Integer" nullable="true"/>
