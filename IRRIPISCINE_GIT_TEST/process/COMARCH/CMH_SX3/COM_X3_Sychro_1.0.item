    <nodeData xsi:type="TalendMapper:MapperData">
      <uiProperties/>
      <varTables sizeState="INTERMEDIATE" name="Var">
        <mapperTableEntries name="Compteur_Num" expression="//if customers&#xD;&#xA;((String)globalMap.get(&quot;tFileList_4_CURRENT_FILE&quot;)).contains(&quot;client&quot;) ?&#xA;//Récupération de la colonne numéro 6&#xD;&#xA;//StringHandling.EREPLACE(row29.line,&quot;^(?:[^|]*\\|){5}([^|]*)\\|(.*)$&quot;,&quot;$1&quot;) :&#xA;ExtractString.BetweenPipes(row29.line, 6) :&#xA;&#xD;&#xA;// if commande projet&#xD;&#xA;((String)globalMap.get(&quot;tFileList_4_CURRENT_FILE&quot;)).contains(&quot;vcs&quot;) ?&#xD;&#xA;row29.line.contains(&quot;CDE&quot;) ? &#xA;//Récupération de la colonne numéro 6&#xD;&#xA;//StringHandling.EREPLACE(row29.line,&quot;^(?:[^|]*\\|){5}([^|]*)\\|(.*)$&quot;,&quot;$1&quot;) :&#xA;ExtractString.BetweenPipes(row29.line, 6) :&#xA;&#xD;&#xA;row29.line.contains(&quot;ADRS&quot;) ? &#xA;//Récupération de la colonne numéro 5&#xD;&#xA;//StringHandling.EREPLACE(row29.line,&quot;^(?:[^|]*\\|){4}([^|]*)\\|(.*)$&quot;,&quot;$1&quot;) : &quot;&quot;&#xA;ExtractString.BetweenPipes(row29.line, 5) : &quot;&quot;&#xD;&#xA;:&#xA;// if Ventes&#xD;&#xA;((String)globalMap.get(&quot;tFileList_4_CURRENT_FILE&quot;)).contains(&quot;autre&quot;) ?&#xD;&#xA;row29.line.contains(&quot;APPMVT&quot;)? &#xA;//Récupération de la colonne numéro 10&#xD;&#xA;//StringHandling.EREPLACE(row29.line,&quot;^(?:[^|]*\\|){11}([^|]*)\\|(.*)$&quot;,&quot;$1&quot;) :&#xA;ExtractString.BetweenPipes(row29.line, 12) :&#xA;&#xD;&#xA;row29.line.contains(&quot;MVTFINAN&quot;) ?&#xA;//Récupération de la colonne numéro 10 &#xD;&#xA;//StringHandling.EREPLACE(row29.line,&quot;^(?:[^|]*\\|){11}([^|]*)\\|(.*)$&quot;,&quot;$1&quot;) : &quot;&quot;&#xA;ExtractString.BetweenPipes(row29.line, 12)  : &quot;&quot; &#xD;&#xA;: &quot;&quot; " type="id_String"/>
        <mapperTableEntries name="Number8ofcompteur_num" expression="//Récupération du 8 caractère du compteur num&#xD;&#xA;Var.Compteur_Num.trim().length() >= 8 ?&#xA;Var.Compteur_Num.substring(7,8) : &quot;&quot; " type="id_String"/>
        <mapperTableEntries name="IsNotLetter" expression="// Vérification du type du 8 ème caractère Chiffre ou lettre&#xD;&#xA;(Var.Number8ofcompteur_num.equals(&quot;&quot;) || Var.Number8ofcompteur_num.equals(&quot; &quot;)) ? true :&#xD;&#xD;&#xA;Var.Number8ofcompteur_num.matches(&quot;\\d&quot;) " type="id_Boolean"/>
        <mapperTableEntries name="Compteur_NUM_to_use" expression="//Traitement du compteur numéro -- supp espace ou récupération de la bonne partie du compteur num&#xD;&#xA;Var.Compteur_Num.trim().length() == 8 ? Var.Compteur_Num.trim() :  &#xD;&#xD;&#xA;Var.Compteur_Num.trim().length() > 8 &amp;&amp; Var.IsNotLetter == true ?&#xA;&#xD;&#xA;Var.Compteur_Num.substring(7,15) : &#xD;&#xD;&#xA;Var.Compteur_Num.trim() " type="id_String"/>
        <mapperTableEntries name="indexDebut" expression="//Récupération de l'index de début du compteur num pour remplacement&#xD;&#xA;//if customers&#xA;((String)globalMap.get(&quot;tFileList_4_CURRENT_FILE&quot;)).contains(&quot;client&quot;) ?&#xA;//Récupération de la colonne numéro 6&#xA;row29.line.indexOf(Var.Compteur_Num ) :&#xA;&#xA;// if commande projet&#xA;((String)globalMap.get(&quot;tFileList_4_CURRENT_FILE&quot;)).contains(&quot;vcs&quot;) ?&#xA;row29.line.contains(&quot;CDE&quot;) ? &#xA;//Récupération de la colonne numéro 6&#xA;row29.line.indexOf(Var.Compteur_Num )  :&#xA;&#xA;row29.line.contains(&quot;ADRS&quot;) ? &#xA;//Récupération de la colonne numéro 5&#xA;row29.line.indexOf(Var.Compteur_Num ) &#xA;: 0&#xA;:&#xA;// if Ventes&#xA;((String)globalMap.get(&quot;tFileList_4_CURRENT_FILE&quot;)).contains(&quot;autre&quot;) ?&#xA;row29.line.contains(&quot;APPMVT&quot;)? &#xA;//Récupération de la colonne numéro 10&#xA;row29.line.indexOf(Var.Compteur_Num ) :&#xA;&#xA;row29.line.contains(&quot;MVTFINAN&quot;) ?&#xA;//Récupération de la colonne numéro 10 &#xA;row29.line.indexOf(Var.Compteur_Num )  : 0&#xA;: 0 " type="id_Integer"/>
        <mapperTableEntries name="indexFin" expression="//if customers&#xD;&#xA;((String)globalMap.get(&quot;tFileList_4_CURRENT_FILE&quot;)).contains(&quot;client&quot;) ?&#xD;&#xA;//Récupération de la colonne numéro 6&#xD;&#xA;row29.line.indexOf(Var.Compteur_Num ) + Var.Compteur_Num.length()  :&#xD;&#xA;&#xD;&#xA;// if commande projet&#xD;&#xA;((String)globalMap.get(&quot;tFileList_4_CURRENT_FILE&quot;)).contains(&quot;vcs&quot;) ?&#xD;&#xA;row29.line.contains(&quot;CDE&quot;) ? &#xD;&#xA;//Récupération de la colonne numéro 6&#xD;&#xA;row29.line.indexOf(Var.Compteur_Num ) + Var.Compteur_Num.length()  :&#xD;&#xA;&#xD;&#xA;row29.line.contains(&quot;ADRS&quot;) ? &#xD;&#xA;//Récupération de la colonne numéro 5&#xD;&#xA;row29.line.indexOf(Var.Compteur_Num ) + Var.Compteur_Num.length() &#xD;&#xA;: 0&#xD;&#xA;:&#xD;&#xA;// if Ventes&#xD;&#xA;((String)globalMap.get(&quot;tFileList_4_CURRENT_FILE&quot;)).contains(&quot;autre&quot;) ?&#xD;&#xA;row29.line.contains(&quot;APPMVT&quot;)? &#xD;&#xA;//Récupération de la colonne numéro 10&#xD;&#xA;row29.line.indexOf(Var.Compteur_Num ) + Var.Compteur_Num.length() :&#xD;&#xA;&#xD;&#xA;row29.line.contains(&quot;MVTFINAN&quot;) ?&#xD;&#xA;//Récupération de la colonne numéro 10 &#xD;&#xA;row29.line.indexOf(Var.Compteur_Num ) + Var.Compteur_Num.length()  : 0&#xD;&#xA;: 0 " type="id_Integer"/>
      </varTables>
