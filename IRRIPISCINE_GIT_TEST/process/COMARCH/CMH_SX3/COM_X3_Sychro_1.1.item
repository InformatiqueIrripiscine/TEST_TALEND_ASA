    </metadata>
    <metadata connector="FLOW" name="out2">
      <column comment="" key="false" length="-1" name="Compteur_Num" nullable="false" pattern="" precision="-1" sourceType="" type="id_String" originalLength="-1" usefulColumn="true"/>
      <column comment="" key="false" length="-1" name="Number8ofcompteur_num" nullable="false" pattern="" precision="-1" sourceType="" type="id_String" originalLength="-1" usefulColumn="true"/>
      <column comment="" defaultValue="" key="false" length="-1" name="IsNotLetter" nullable="true" pattern="" precision="-1" sourceType="" type="id_Boolean" originalLength="-1" usefulColumn="true"/>
      <column comment="" key="false" length="-1" name="Compteur_NUM_to_use" nullable="false" pattern="" precision="-1" sourceType="" type="id_String" originalLength="-1" usefulColumn="true"/>
      <column comment="" defaultValue="" key="false" length="-1" name="indexDebut" nullable="true" pattern="" precision="-1" sourceType="" type="id_Integer" originalLength="-1" usefulColumn="true"/>
      <column comment="" defaultValue="" key="false" length="-1" name="indexFin" nullable="false" pattern="" precision="-1" sourceType="" type="id_Integer" originalLength="-1" usefulColumn="true"/>
    </metadata>
    <nodeData xsi:type="TalendMapper:MapperData">
      <uiProperties/>
      <varTables sizeState="INTERMEDIATE" name="Var">
        <mapperTableEntries name="Compteur_Num" expression="//if customers&#xD;&#xA;((String)globalMap.get(&quot;tFileList_4_CURRENT_FILE&quot;)).contains(&quot;client&quot;) ?&#xA;//Récupération de la colonne numéro 6&#xD;&#xA;//StringHandling.EREPLACE(row29.line,&quot;^(?:[^|]*\\|){5}([^|]*)\\|(.*)$&quot;,&quot;$1&quot;) :&#xA;ExtractString.BetweenPipes(row29.line, 6) :&#xA;&#xD;&#xA;// if commande projet&#xD;&#xA;((String)globalMap.get(&quot;tFileList_4_CURRENT_FILE&quot;)).contains(&quot;vcs&quot;) ?&#xD;&#xA;row29.line.contains(&quot;CDE&quot;) ? &#xA;//Récupération de la colonne numéro 6&#xD;&#xA;//StringHandling.EREPLACE(row29.line,&quot;^(?:[^|]*\\|){5}([^|]*)\\|(.*)$&quot;,&quot;$1&quot;) :&#xA;ExtractString.BetweenPipes(row29.line, 6) :&#xA;&#xD;&#xA;row29.line.contains(&quot;ADRS&quot;) ? &#xA;//Récupération de la colonne numéro 5&#xD;&#xA;//StringHandling.EREPLACE(row29.line,&quot;^(?:[^|]*\\|){4}([^|]*)\\|(.*)$&quot;,&quot;$1&quot;) : &quot;&quot;&#xA;ExtractString.BetweenPipes(row29.line, 5) : &quot;&quot;&#xD;&#xA;:&#xA;// if Ventes&#xD;&#xA;((String)globalMap.get(&quot;tFileList_4_CURRENT_FILE&quot;)).contains(&quot;autre&quot;) ?&#xD;&#xA;row29.line.contains(&quot;APPMVT&quot;)? &#xA;//Récupération de la colonne numéro 10&#xD;&#xA;//StringHandling.EREPLACE(row29.line,&quot;^(?:[^|]*\\|){11}([^|]*)\\|(.*)$&quot;,&quot;$1&quot;) :&#xA;ExtractString.BetweenPipes(row29.line, 12) :&#xA;&#xD;&#xA;row29.line.contains(&quot;MVTFINAN&quot;) ?&#xA;//Récupération de la colonne numéro 10 &#xD;&#xA;//StringHandling.EREPLACE(row29.line,&quot;^(?:[^|]*\\|){11}([^|]*)\\|(.*)$&quot;,&quot;$1&quot;) : &quot;&quot;&#xA;ExtractString.BetweenPipes(row29.line, 12)  : &quot;&quot; &#xD;&#xA;: &quot;&quot; " type="id_String"/>
        <mapperTableEntries name="Number8ofcompteur_num" expression="//Récupération du 8 caractère du compteur num&#xD;&#xA;Var.Compteur_Num.trim().length() >= 8 ?&#xA;Var.Compteur_Num.substring(7,8) : &quot;&quot; " type="id_String"/>
        <mapperTableEntries name="IsNotLetter" expression="// Vérification du type du 8 ème caractère Chiffre ou lettre&#xD;&#xA;(Var.Number8ofcompteur_num.equals(&quot;&quot;) || Var.Number8ofcompteur_num.equals(&quot; &quot;)) ? true :&#xD;&#xD;&#xA;Var.Number8ofcompteur_num.matches(&quot;\\d&quot;) " type="id_Boolean"/>
