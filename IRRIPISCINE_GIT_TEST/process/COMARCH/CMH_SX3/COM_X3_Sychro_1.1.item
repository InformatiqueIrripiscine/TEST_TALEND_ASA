        <mapperTableEntries name="check_TVA_FR_isValid" expression="(!Var.TVA_FR.equals(&quot;&quot;) &amp;&amp; Var.Col_48_TVA_with_trim.length()!= 13 &amp;&amp; Var.Col_48_TVA_with_trim.length()!= 0) ? false :&#xD;&#xA;Var.Col_48_TVA_with_trim.matches(&quot;^FR0+$&quot;) ? false :&#xD;&#xA;Var.Col_48_TVA_with_trim.matches(&quot;^FR.*[A-Za-z].*$&quot;) ? false :&#xD;&#xA;true " type="id_Boolean"/>
