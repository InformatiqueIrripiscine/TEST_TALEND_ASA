        <mapperTableEntries name="IndexDebutTVA" expression="Var.check_TVA_FR_isValid == false ?&#xD;&#xA;row38.line.indexOf(Var.Col_48_TVA)  :&#xD;&#xA;0 " type="id_Integer"/>
        <mapperTableEntries name="indexFinTVA" expression="Var.check_TVA_FR_isValid == false ?&#xD;&#xA;Var.IndexDebutTVA +  Var.Col_48_TVA.length()  :&#xD;&#xA;0 " type="id_Integer"/>
      </varTables>
      <outputTables sizeState="INTERMEDIATE" name="out9" activateExpressionFilter="true" activateCondensedTool="true">
        <mapperTableEntries name="line" expression="Var.check_TVA_FR_isValid == false ?&#xD;&#xA;row38.line.substring(0, Var.IndexDebutTVA) + Var.Col_TVA_to_use + row38.line.substring(Var.indexFinTVA)  :&#xD;&#xA;row38.line " type="id_String" nullable="true"/>
      </outputTables>
      <inputTables sizeState="INTERMEDIATE" name="row38" matchingMode="UNIQUE_MATCH" lookupMode="LOAD_ONCE">
