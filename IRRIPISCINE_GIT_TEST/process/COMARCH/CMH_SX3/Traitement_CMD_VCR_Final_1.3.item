        <mapperTableEntries name="message" expression="&quot;Votre commande RAPIDE &quot;&#xD;&#xA;+ ExtractString.BetweenPipes(row44.line,4)&#xD;&#xA;+ &quot; a bien été prise en compte par la centrale Irripiscine&quot;&#xD;&#xA;+ &quot;&lt;br/>&quot;&#xA;+ &quot;&lt;br/>&quot;&#xD;&#xA;+ (&#xD;&#xA;    ExtractString.BetweenPipes(row44.line,7) != null &amp;&amp; !ExtractString.BetweenPipes(row44.line,7).isEmpty()&#xD;&#xA;    ? &quot;Les articles ci-dessous ont été retirés de votre commande car ils ne sont pas éligibles à la commande rapide : &quot;&#xD;&#xA;        + &quot;&lt;br/>&quot;&#xA;        + &quot;&lt;br/>&quot;&#xD;&#xA;        + ExtractString.BetweenPipes(row44.line,7)&#xD;&#xA;    : &quot;Tous les articles de votre commande sont éligibles à la commande rapide.&quot;&#xD;&#xA;  )&#xD;&#xA;+ &quot;&lt;br/>&quot;&#xA;+ &quot; &lt;br/>&quot;&#xD;&#xA;+ &quot; - Voici le récapitulatif de la commande prise en compte : &lt;br/>&quot;&#xD;&#xA;+ &quot; &lt;br/>&quot;&#xD;&#xA;+ &quot; Client : &quot; + ExtractString.BetweenPipes(row44.line,3) + &quot;&lt;br/>&quot;&#xD;&#xA;+ &quot; Numéro de commande Magasin : &quot; + ExtractString.BetweenPipes(row44.line,4) + &quot;&lt;br/>&quot;&#xD;&#xA;+ &quot; Numéro de commande Centrale : &quot; + ExtractString.BetweenPipes(row44.line,5) + &quot;&lt;br/>&lt;br/>&quot;&#xD;&#xA;&#xD;&#xA;+ &quot;Voici le tableau récap de votre commande :&lt;br/>&quot;&#xD;&#xA;&#xD;&#xA;+ &quot;&lt;table border='1' style='border-collapse:collapse;'>&quot;&#xD;&#xA;+ &quot;&lt;tr>&quot;&#xD;&#xA;+ &quot;&lt;th>Référence Article&lt;/th>&quot;&#xA;+ &quot;&lt;th>Désignation Article&lt;/th>&quot;&#xD;&#xA;+ &quot;&lt;th>Quantité&lt;/th>&quot;&#xD;&#xA;+ &quot;&lt;th>Tarif Unitaire&lt;/th>&quot;&#xA;+ &quot;&lt;th>Stock&lt;/th>&quot;&#xA;+ &quot;&lt;th>Total Ligne&lt;/th>&quot;&#xD;&#xA;+ &quot;&lt;/tr>&quot;&#xD;&#xA;+ &quot;&lt;tr>&quot;&#xA;+ &quot;&lt;td align='center'>&quot; + ExtractString.BetweenPipes(row44.line,6).replaceAll(&quot;\