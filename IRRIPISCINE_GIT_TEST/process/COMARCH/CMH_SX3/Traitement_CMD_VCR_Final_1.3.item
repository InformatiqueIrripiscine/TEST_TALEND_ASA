\s*,\\s*&quot;, &quot;&lt;br/>&quot;) + &quot;&lt;/td>&quot;&#xA;+ &quot;&lt;td align='center'>&quot; + ExtractString.BetweenPipes(row44.line,12).replaceAll(&quot;\\s*,\\s*&quot;, &quot;&lt;br/>&quot;) + &quot;&lt;/td>&quot;&#xA;+ &quot;&lt;td align='center'>&quot; + ExtractString.BetweenPipes(row44.line,8).replaceAll(&quot;\\s*,\\s*&quot;, &quot;&lt;br/>&quot;) + &quot;&lt;/td>&quot;&#xA;+ &quot;&lt;td align='center'>&quot; + ExtractString.BetweenPipes(row44.line,9).replaceAll(&quot;\\s*,\\s*&quot;, &quot;&lt;br/>&quot;) + &quot;&lt;/td>&quot;&#xA;+ &quot;&lt;td align='center'>&quot; + ExtractString.BetweenPipes(row44.line,10).replaceAll(&quot;\\s*,\\s*&quot;, &quot;&lt;br/>&quot;) + &quot;&lt;/td>&quot;&#xA;+ &quot;&lt;td align='center'>&quot; + ExtractString.BetweenPipes(row44.line,11).replaceAll(&quot;\\s*,\\s*&quot;, &quot;&lt;br/>&quot;) + &quot;&lt;/td>&quot;&#xA;+ &quot;&lt;/tr>&quot;&#xD;&#xA;+ &quot;&lt;/table>&quot;&#xD;&#xA;&#xD;&#xA;+ &quot;&lt;br/>&quot;&#xA;+&quot;Pour toute questions ou demande, veuillez répondre à ce ticket&lt;br/>&quot;  " type="id_String"/>
