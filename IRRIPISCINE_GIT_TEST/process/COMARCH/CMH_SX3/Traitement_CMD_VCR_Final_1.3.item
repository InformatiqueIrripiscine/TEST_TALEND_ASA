    <elementParameter field="MEMO_JAVA" name="CODE" value="&#xA;&#xA;&#xA;String[] champs = input_row.line.split(&quot;\\|&quot;, -1);&#xA;&#xA;&#xA;if (ExtractString.BetweenPipes(input_row.line, 1).equals(&quot;CDE&quot;)){&#xA;&#x9;//copie du code depôt dans la col 12 &#xA;&#x9;champs[11] = champs[2];&#xA;&#x9;//changement de la date par aujourd'hui + 2  col 9&#xA;&#x9;champs[8] = TalendDate.formatDate(&quot;yyyyMMdd&quot;, TalendDate.addDate(TalendDate.getCurrentDate(), 2, &quot;dd&quot;));&#xA;&#x9;output_row.line = String.join(&quot;|&quot;, champs);&#xA;&#xA;}&#xA;else{&#xA;&#x9;output_row.line = input_row.line;&#xA;&#x9;}&#xA;"/>
