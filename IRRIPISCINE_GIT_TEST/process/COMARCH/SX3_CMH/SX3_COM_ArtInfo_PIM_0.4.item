    <elementParameter field="MEMO_JAVA" name="CODE" value="// Enregistrer la date d'exécution du job dans la variable globale Date_Exec&#xA;//globalMap.put(&quot;Date_Exec&quot;, TalendDate.formatDate(&quot;yyyy-MM-dd HH:mm:ss&quot;, TalendDate.getCurrentDate()));&#xA;&#xA;//String EXEC_Date = TalendDate.formatDateInUTC(&quot;YYYY-MM-dd HH:mm:ss&quot;, TalendDate.getCurrentDate());&#xA;&#xA;//String MAJ_Date = TalendDate.formatDateInUTC(&quot;YYYY-MM-dd HH:mm:ss&quot;, TalendDate.parseDate(&quot;dd-MM-YYYY HH:mm:ss&quot;, context.Last_Exec_Date_Heure_CMH_X3_Input) );&#xA;&#xA;// Définir l'url de l'API à appeler&#xA;//String URL_API = context.Pim_url + &quot;/api/rest/v1/products?search=&quot; + URLEncoder.encode(&quot;{\&quot;updated\&quot;:[{\&quot;operator\&quot;:\&quot;>\&quot;,\&quot;value\&quot;:\&quot;&quot; + MAJ_Date + &quot;\&quot;}]}&quot;);&#xA;&#xA;//Liste des attributs à synchroniser&#xA;String list_attributes = &quot;GARANTIE_CONSTRUCTEUR,GARANTIE_SUPPLEMENTAIRE_IRRIJARDIN,CANAUX_VENTE_POSSIBLES,DESIGNATION_COMMERCIALE,PAYS_COMMANDE_RAPIDE&quot;;&#xA;&#xA;String URL_API = context.Pim_url+ &quot;/api/rest/v1/products?pagination_type=search_after&amp;limit=100&amp;attributes=&quot;+list_attributes;&#xA;&#xA;//String URL_API = context.Pim_url + &quot;/api//rest/v1/products?search=&quot; + &quot;{\&quot;identifier\&quot;:[{\&quot;operator\&quot;:\&quot;IN\&quot;,\&quot;value\&quot;:[&quot; + ((String)globalMap.get(&quot;Filter_identifier&quot;)) + &quot; ]}]}&quot;+&quot;&amp;limit=100&amp;attributes=&quot;+list_attributes;&#xA;&#xA;&#xA;// Afficher l'url&#xA;//System.out.println(URL_API);&#xA;//System.out.println(&quot;PARIS: &quot; +context.Last_Exec_Date_Heure_CMH_X3_Input);&#xA;//System.out.println(&quot;UTC LAST MAJ: &quot; + MAJ_Date);&#xA;//System.out.println(&quot;UTC EXEC: &quot; + ((String)globalMap.get(&quot;Filter_identifier&quot;)) );&#xA;&#xA;&#xA;&#xA;// Enregistrer l'url dans la variable globale URL_API&#xA;//globalMap.put(&quot;URL_API&quot;, URL_API);&#xA;&#xA;&#xA;&#xA;&#xA;// Appeler l'API et générer les fichiers de sorties&#xA;API_handling.ApiRequestAllPages(URL_API, ((String)globalMap.get(&quot;PIM_Folder&quot;)), &quot;products&quot;, &quot;.json&quot;, context.Pim_authorization);"/>
