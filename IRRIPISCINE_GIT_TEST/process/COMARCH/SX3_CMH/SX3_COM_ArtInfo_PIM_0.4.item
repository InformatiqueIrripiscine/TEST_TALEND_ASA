    <elementParameter field="MEMO_JAVA" name="CODE" value="// Alimentation de la variable de contexte Magento_authorization et affichage de sa valeur dans la console&#xA;context.Pim_authorization = &quot;Bearer &quot;+ StringHandling.EREPLACE(input_row.access_token, &quot;\&quot;&quot;, &quot;&quot;);&#xA;System.out.println(context.Pim_authorization);&#xA;"/>
