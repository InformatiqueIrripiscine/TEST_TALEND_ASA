    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT a.ITMREF_0,&#xD;&#xA;&#x9;&#x9;a.EANBPS_0,&#xD;&#xA;&#x9;&#x9;a.EANTYP_0,&#xD;&#xA;&#x9;&#x9;a.BPSNUM_0,&#xD;&#xA;&#x9;&#x9;a.EANCODE_0,&#xD;&#xA;&#x9;&#x9;a.CMH_STU_0,&#xD;&#xA;&#x9;&#x9;a.LASUPDDAT_0&quot;&#xD;&#xA;+&quot;&#xD;&#xA;FROM&#x9;\&quot;&quot;+context.Sage_X3_Schema+&quot;\&quot;.YVITMEAN a&#xD;&#xA;INNER JOIN \&quot;&quot;+context.Sage_X3_Schema+&quot;\&quot;.YVITMPIM itm on a.ITMREF_0 = itm.ITMREF_0&#xD;&#xA;WHERE a.LASUPDDAT_0 >=CAST('&quot; + context.Last_Exec_Date_Heure_CMH_X3_Input  + &quot;' AS DATETIME)&#xD;&#xA;--AND        a.LASUPDDAT_0 &lt;=CAST('&quot; + context.Last_Exec_Date_Heure_CMH_X3_input2  + &quot;' AS DATETIME)&#xD;&#xA;AND itm.ITMREF_0 IN (SELECT A.ID FROM #Article_Trans_CMH  A)&#xD;&#xA;AND itm.CMH_ARTICLE_ACTIF = 1&#x9;--Article Actif&#xD;&#xA;AND&#x9;(&#xD;&#xA;&#x9;&#x9;LEN(ISNULL(itm.SBSITM_0, '')) = 0&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;-- Article non substitué&#xD;&#xA;&#x9;&#x9;OR&#xD;&#xA;&#x9;&#x9;(LEN(ISNULL(itm.SBSITM_0, '')) > 0 AND itm.ITMREF_0 IN (SELECT A2.ID FROM #Article_Trans_CMH  A2))&#x9;-- Article substitué et substituant transmis.&#xD;&#xA;&#x9;)&#xD;&#xA;&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false" show="false"/>
