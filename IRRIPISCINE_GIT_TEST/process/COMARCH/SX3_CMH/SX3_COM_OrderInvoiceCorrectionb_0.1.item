    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT a.X_SITEMAG_0,&#xD;&#xA;&#x9;&#x9;a.PNHNUM_0,&#xD;&#xA;&#x9;&#x9;a.PNDLIN_0,&#xD;&#xA;&#x9;&#x9;a.RTNDAT_0,&#xD;&#xA;&#x9;&#x9;a.ITMREF_0,&#xD;&#xA;&#x9;&#x9;a.QTYSTU_0,&#xD;&#xA;&#x9;&#x9;a.LINAMT_0,&#xD;&#xA;&#x9;&#x9;a.ZCMH_0,&#xD;&#xA;&#x9;&#x9;a.AUZNUM_0,&#xD;&#xA;&#x9;&#x9;a.LINTEX_0,&#xD;&#xA;&#x9;&#x9;a.CREDAT_0&#xD;&#xA;FROM&#x9;\&quot;&quot;+context.Sage_X3_Schema+&quot;\&quot;.YVRETURN a&#xD;&#xA;WHERE a.CREDAT_0 >=CAST('&quot; + context.Last_Exec_Date_Heure_CMH_X3_Input  + &quot;' AS DATE)&#xD;&#xA;AND a.PNHNUM_0 NOT IN ( SELECT A1.ID FROM #OrderInvoicesCorrections_Trans_CMH A1)&#xD;&#xA;AND EXISTS&#xD;&#xA;(&#x9;&#x9;&#x9;&#xD;&#xA;&#x9;&#x9;&#x9;SELECT *&#xD;&#xA;&#x9;&#x9;&#x9;FROM&#x9;\&quot;&quot;+context.Sage_X3_Schema+&quot;\&quot;.YVRETURN Z1 WITH(NOLOCK)&#xD;&#xA;&#x9;&#x9;&#x9;INNER JOIN \&quot;&quot;+context.Sage_X3_Schema+&quot;\&quot;.ITMMASTER Z2 WITH(NOLOCK) ON Z2.ITMREF_0 = Z1.ITMREF_0&#xD;&#xA;&#xD;&#xA;&#x9;&#x9;&#x9;WHERE Z1.PNHNUM_0 = a.PNHNUM_0&#xD;&#xA;&#x9;&#x9;&#x9;AND  &#xD;&#xA;&#x9;&#x9;   (&#xD;&#xA;&#x9;&#x9;&#x9;Z1.ITMREF_0 NOT IN ( SELECT * FROM #Article_Trans_CMH)&#xD;&#xA;&#x9;&#x9;&#x9;OR&#xD;&#xA;&#x9;&#x9;&#x9; \&quot;&quot;+context.Sage_X3_Schema+&quot;\&quot;.[F_CMH_ARTICLE_ACTIF] (Z2.ITMSTA_0, Z2.STOMGTCOD_0 , Z2.XCRESIT_0, Z2.XVPC_0) &lt;> 1&#x9;--Article Actif&#xD;&#xA;&#xD;&#xA;&#x9;&#x9;&#x9; )&#xD;&#xA;&#xD;&#xA;)&#xD;&#xA;&#xD;&#xA;&quot;"/>
