    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;CREATE TABLE #PriceToSynchronise2 ( &#xD;&#xA; PLI_0 [nvarchar](20) COLLATE &quot;+context.Sage_X3_Collate_Type+&quot;, &#xD;&#xA;PLICRD_0 [nvarchar](20) COLLATE &quot;+context.Sage_X3_Collate_Type+&quot;,&#xD;&#xA;PLILIN_0 [nvarchar](20) COLLATE &quot;+context.Sage_X3_Collate_Type+&quot;, &#xD;&#xA;ITMREF_0 [nvarchar](20) COLLATE &quot;+context.Sage_X3_Collate_Type+&quot;, &#xD;&#xA;ITMSTA_0 [nvarchar](20) COLLATE &quot;+context.Sage_X3_Collate_Type+&quot;, &#xD;&#xA;STOMGTCOD_0 [nvarchar](20) COLLATE &quot;+context.Sage_X3_Collate_Type+&quot;,  &#xD;&#xA;XCRESIT_0 [nvarchar](20) COLLATE &quot;+context.Sage_X3_Collate_Type+&quot;,  &#xD;&#xA;XVPC_0 [nvarchar](20) COLLATE &quot;+context.Sage_X3_Collate_Type+&quot;,&#xD;&#xA;LASUPDDAT_0  [nvarchar](20) COLLATE &quot;+context.Sage_X3_Collate_Type+&quot;);&#xD;&#xA;&#xD;&#xA;CREATE TABLE #PriceToSynchronise ( &#xD;&#xA; PLI_0 [nvarchar](20) COLLATE &quot;+context.Sage_X3_Collate_Type+&quot;, &#xD;&#xA;PLICRD_0 [nvarchar](20) COLLATE &quot;+context.Sage_X3_Collate_Type+&quot;,&#xD;&#xA;PLILIN_0 [nvarchar](20) COLLATE &quot;+context.Sage_X3_Collate_Type+&quot;, &#xD;&#xA;ITMREF_0 [nvarchar](20) COLLATE &quot;+context.Sage_X3_Collate_Type+&quot;, &#xD;&#xA;ITMSTA_0 [nvarchar](20) COLLATE &quot;+context.Sage_X3_Collate_Type+&quot;, &#xD;&#xA;STOMGTCOD_0 [nvarchar](20) COLLATE &quot;+context.Sage_X3_Collate_Type+&quot;,  &#xD;&#xA;XCRESIT_0 [nvarchar](20) COLLATE &quot;+context.Sage_X3_Collate_Type+&quot;,  &#xD;&#xA;XVPC_0 [nvarchar](20) COLLATE &quot;+context.Sage_X3_Collate_Type+&quot;,&#xD;&#xA;LASUPDDAT_0  [nvarchar](20) COLLATE &quot;+context.Sage_X3_Collate_Type+&quot;);&#xD;&#xA;&#xD;&#xA;INSERT INTO #PriceToSynchronise (  PLI_0 , PLICRD_0, PLILIN_0, ITMREF_0, ITMSTA_0, STOMGTCOD_0, XCRESIT_0, XVPC_0,LASUPDDAT_0 )&#xD;&#xA;SELECT DISTINCT A.PLI_0,&#xD;&#xA;&#x9;&#x9;A.PLICRD_0,&#xD;&#xA;&#x9;&#x9;A.PLILIN_0,&#xD;&#xA;&#x9;&#x9;itm.ITMREF_0, &#xD;&#xA;&