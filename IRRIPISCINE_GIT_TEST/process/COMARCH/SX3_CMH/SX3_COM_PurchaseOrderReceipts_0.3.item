    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT a.X_SITEMAG_0,&#xD;&#xA;&#x9;&#x9;a.ZDATCMH_0,&#xD;&#xA;&#x9;&#x9;a.SOHTYP_0,&#xD;&#xA;&#x9;&#x9;a.YSOHNUM_0,&#xD;&#xA;&#x9;&#x9;a.CUSORDREF_0,&#xD;&#xA;&#x9;&#x9;a.SOHNUM_0,&#xD;&#xA;&#x9;&#x9;a.SOH_CREDAT_0,&#xD;&#xA;&#x9;&#x9;a.POHNUM_0,&#xD;&#xA;&#x9;&#x9;a.X_PCEORI_0,&#xD;&#xA;&#x9;&#x9;a.X_LIGORI_0,&#xD;&#xA;&#x9;&#x9;a.YITMSBSOLD_0,&#xD;&#xA;&#x9;&#x9;a.SOQSTA_0,&#xD;&#xA;&#x9;&#x9;a.ODLQTYSTU_0,&#xD;&#xA;&#x9;&#x9;a.CCLREN_0,&#xD;&#xA;&#x9;&#x9;a.CCLDAT_0,&#xD;&#xA;&#x9;&#x9;a.SOQ_CREDAT_0,&#xD;&#xA;&#x9;&#x9;a.SOQ_ITMREF_0,&#xD;&#xA;&#x9;&#x9;a.SOPLIN_0,&#xD;&#xA;&#x9;&#x9;a.SDDTEX_0,&#xD;&#xA;&#x9;&#x9;a.PTHNUM_0,&#xD;&#xA;&#x9;&#x9;a.SDHNUM_0,&#xD;&#xA;&#x9;&#x9;a.SDDLIN_0,&#xD;&#xA;&#x9;&#x9;a.RCPDAT_0,&#xD;&#xA;&#x9;&#x9;a.PTH_CREDAT_0,&#xD;&#xA;&#x9;&#x9;a.PTH_UPDDAT_0,&#xD;&#xA;&#x9;&#x9;a.PTH_ITMREF_0,&#xD;&#xA;&#x9;&#x9;a.QTYSTU_0,&#xD;&#xA;&#x9;&#x9;a.LINAMT_0,&#xD;&#xA;&#x9;&#x9;a.ZCMH_0,&#xD;&#xA;&#x9;&#x9;a.LASUPDDAT_0&#xD;&#xA;FROM&#x9;\&quot;&quot;+context.Sage_X3_Schema+&quot;\&quot;.YVRECEIPT a&#xD;&#xA;WHERE  a.PTHNUM_0 IN   (SELECT distinct R1.PTHNUM_0 FROM #ReceiptToSynchronise R1)&#xD;&#xA;AND a.PTHNUM_0 NOT IN &#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;( SELECT distinct R2.PTHNUM_0  FROM #ReceiptToSynchronise R2&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;  WHERE NOT (R2.ITMREF_0 IN ( SELECT A2.ID FROM #Article_Trans_CMH A2))&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;  AND \&quot;&quot;+context.Sage_X3_Schema+&quot;\&quot;.[F_CMH_ARTICLE_ACTIF] (R2.ITMSTA_0, R2.STOMGTCOD_0 , R2.XCRESIT_0, R2.XVPC_0) = 1&#x9;--Article Actif &#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;)&#xD;&#xA;AND a.YITMSBSOLD_0&lt;> ''&#xD;&#xA;AND a.PTHNUM_0 IS NOT NULL&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#