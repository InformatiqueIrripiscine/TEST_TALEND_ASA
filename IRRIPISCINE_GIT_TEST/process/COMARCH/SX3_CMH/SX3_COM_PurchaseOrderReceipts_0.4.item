    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT a.X_SITEMAG_0,&#xD;&#xA;&#x9;&#x9;a.ZDATCMH_0,&#xD;&#xA;&#x9;&#x9;a.SOHTYP_0,&#xD;&#xA;&#x9;&#x9;a.YSOHNUM_0,&#xD;&#xA;&#x9;&#x9;a.CUSORDREF_0,&#xD;&#xA;&#x9;&#x9;a.SOHNUM_0,&#xD;&#xA;&#x9;&#x9;a.SOH_CREDAT_0,&#xD;&#xA;&#x9;&#x9;a.POHNUM_0,&#xD;&#xA;&#x9;&#x9;a.X_PCEORI_0,&#xD;&#xA;&#x9;&#x9;a.X_LIGORI_0,&#xD;&#xA;&#x9;&#x9;a.YITMSBSOLD_0,&#xD;&#xA;&#x9;&#x9;a.SOQSTA_0,&#xD;&#xA;&#x9;&#x9;a.ODLQTYSTU_0,&#xD;&#xA;&#x9;&#x9;a.CCLREN_0,&#xD;&#xA;&#x9;&#x9;a.CCLDAT_0,&#xD;&#xA;&#x9;&#x9;a.SOQ_CREDAT_0,&#xD;&#xA;&#x9;&#x9;a.SOQ_ITMREF_0,&#xD;&#xA;&#x9;&#x9;a.SOPLIN_0,&#xD;&#xA;&#x9;&#x9;a.SDDTEX_0,&#xD;&#xA;&#x9;&#x9;a.PTHNUM_0,&#xD;&#xA;&#x9;&#x9;a.SDHNUM_0,&#xD;&#xA;&#x9;&#x9;a.SDDLIN_0,&#xD;&#xA;&#x9;&#x9;a.RCPDAT_0,&#xD;&#xA;&#x9;&#x9;a.PTH_CREDAT_0,&#xD;&#xA;&#x9;&#x9;a.PTH_UPDDAT_0,&#xD;&#xA;&#x9;&#x9;a.PTH_ITMREF_0,&#xD;&#xA;&#x9;&#x9;a.QTYSTU_0,&#xD;&#xA;&#x9;&#x9;a.LINAMT_0,&#xD;&#xA;&#x9;&#x9;a.ZCMH_0,&#xD;&#xA;&#x9;&#x9;a.LASUPDDAT_0&#xD;&#xA;FROM&#x9;\&quot;&quot;+context.Sage_X3_Schema+&quot;\&quot;.YVRECEIPT a&#xD;&#xA;INNER JOIN #PurchaseOrderSold_en_Erreur R ON (a.SOHNUM_0 = R.SOHNUM_0 AND a.SOPLIN_0 = R.SOPLIN_0)&#xD;&#xA;WHERE  a.SOHNUM_0+CAST(a.SOPLIN_0 AS varchar(10)) NOT IN &#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;( SELECT distinct a1.SOHNUM_0+CAST(a1.SOPLIN_0 AS varchar(10)) &#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;  FROM&#x9;\&quot;&quot;+context.Sage_X3_Schema+&quot;\&quot;.YVRECEIPT a1&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;  LEFT JOIN \&quot;&quot;+context.Sage_X3_Schema+&quot;\&quot;.YVITMPIM itm ON a1.SOQ_ITMREF_0= itm.ITMREF_0&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;  WHERE  a1.SOHNUM_0+CAST(a1.SOPLIN_0 AS varchar(10)) IN   (SELECT A2.SOHNUM_0+CAST(A2.SOPLIN_0 AS varchar(10)) FROM #PurchaseOrderSold_en_Erreur A2)&#xD;&#xA;&#x9; &#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;  AND NOT (itm.ITMREF_0 in ( SELECT A3.ID FROM #Article_Trans_CMH A3)&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;  AND itm.CMH_ARTICLE_ACTIF = 1&#x9;) --Article Actif &#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;  &#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;)&#xD;&#xA;AND a.YITMSBSOLD_0=''&#xD;&#xA;&#xD;&#xA;&quot;"/>
