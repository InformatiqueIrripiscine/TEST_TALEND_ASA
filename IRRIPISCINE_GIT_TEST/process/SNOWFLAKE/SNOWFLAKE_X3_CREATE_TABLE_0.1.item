    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;-- Variables &#xD;&#xA;DECLARE @X3_tableName NVARCHAR(50) =&#xD;&#xA;    '&quot;+((String)globalMap.get(&quot;table_to_create.X3_SCHEMA&quot;))+&quot;.&quot;+((String)globalMap.get(&quot;table_to_create.X3_TABLE_NAME&quot;))+&quot;';&#xD;&#xA;&#xD;&#xA;DECLARE @SF_tableName NVARCHAR(50) =&#xD;&#xA;    '&quot;+((String)globalMap.get(&quot;table_to_create.SF_TABLE_NAME&quot;))+&quot;';&#xD;&#xA;DECLARE @SF_DbSchema NVARCHAR(50) = '&#xD;&#xA;&#x9;&quot;+((String)globalMap.get(&quot;Db_Schema_Bronze&quot;))+&quot;';&#xD;&#xA;&#xD;&#xA;DECLARE @Resultat NVARCHAR(MAX);&#xD;&#xA;DECLARE @NbColonnes INT;&#xD;&#xA;&#xD;&#xA;-- Génération du CREATE TABLE &#xD;&#xA;SELECT &#xD;&#xA;    @Resultat =&#xD;&#xA;        'CREATE TABLE ' +@SF_DbSchema+'.' +@SF_tableName + ' (' + CHAR(10) +&#xD;&#xA;        STRING_AGG(&#xD;&#xA;            CAST(&#xD;&#xA;                COLUMN_NAME + ' ' + DATA_TYPE +&#xD;&#xA;                CASE &#xD;&#xA;                    -- ❗ nvarchar(max) → nvarchar (sans taille)&#xD;&#xA;                    WHEN DATA_TYPE = 'nvarchar' AND CHARACTER_MAXIMUM_LENGTH = -1 THEN ''&#xD;&#xA;                    &#xD;&#xA;                    -- autres types avec taille&#xD;&#xA;                    WHEN DATA_TYPE IN ('char', 'nchar', 'varchar', 'nvarchar', 'binary', 'varbinary') THEN&#xD;&#xA;                        '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS NVARCHAR) + ')'&#xD;&#xA;                    &#xD;&#xA;                    ELSE ''&#xD;&#xA;                END&#xD;&#xA;                AS NVARCHAR(MAX)&#xD;&#xA;            ),&#xD;&#xA;            ',' + CHAR(10)&#xD;&#xA;        ) WITHIN GROUP (ORDER BY ORDINAL_POSITION)&#xD;&#xA;        + CHAR(10) + ');',&#xD;&#xA;    @NbColonnes = COUNT(*)&#xD;&#xA;FROM INFORMATION_SCHEMA.COLUMNS&#xD;&#xA;WHERE TABLE_SCHEMA + '.' + TABLE_NAME = @X3_tableName;&#xD;&#xA;&#xD;&#xA;-- Retour du résultat&#xD;&#xA;SELECT &#xD;&#xA;    @Resultat   AS CREATE_TABLE_SQL_SCRIPTS,&#xD;&#xA;    @NbColonnes AS NB_COLONNES;&#xD;&#xA;&quot;&#xD;&#xA;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false" show="false"/>
    <elementParameter field="TEXT" name="DATASOURCE_ALIAS" value="&quot;&quot;" show="false"/>
    <elementParameter field="MAPPING_TYPE" name="MAPPING" value="id_MSSQL" show="false"/>
    <elementParameter field="TEXT" name="PROPERTIES" value="&quot;noDatetimeStringSync=true&quot;" show="false"/>
    <elementParameter field="ENCODING_TYPE" name="ENCODING" value="&quot;ISO-8859-15&quot;" show="false"/>
