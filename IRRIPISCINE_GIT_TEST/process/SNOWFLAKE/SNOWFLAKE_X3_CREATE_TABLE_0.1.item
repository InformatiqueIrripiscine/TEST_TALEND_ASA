      <elementValue elementRef="SCHEMA_COLUMN" value="CREATE_TABLE_SQL_SCRIPTS"/>
      <elementValue elementRef="TRIM" value="false"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="NB_COLONNES"/>
      <elementValue elementRef="TRIM" value="false"/>
    </elementParameter>
    <elementParameter field="TEXT" name="LABEL" value="INFORMATION_SCHEMA.COLUMNS&lt;br>&lt;b>Construction scripts create table&lt;/b>"/>
