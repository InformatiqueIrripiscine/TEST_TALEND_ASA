  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="480" posY="448">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_1" show="false"/>
    <elementParameter field="MEMO_JAVA" name="CODE" value="// Création du scripts SQL Select&#xA;&#xA;String Last_Exec_Value = TalendDate.formatDate(&quot;yyyy-MM-dd HH:mm:ss&quot;, ((java.util.Date)globalMap.get(&quot;tables.LAST_EXEC&quot;)));&#xA;&#xA;// Construction du SELECT&#xA;String SQL_QUERY_SELECT = &quot;SELECT * FROM &quot; +((String)globalMap.get(&quot;tables.X3_SCHEMA&quot;))+&quot;.&quot;+((String)globalMap.get(&quot;tables.X3_TABLE_NAME&quot;))+&quot; WITH(nolock) WHERE 1=1 &quot;  ;&#xA;String SQL_QUERY_CONDITION = &quot;&quot;;&#xA;&#xA;if(!Relational.ISNULL(((String)globalMap.get(&quot;tables.DELTA_DATETIME_COLUMNS&quot;))) &amp;&amp; !((String)globalMap.get(&quot;tables.DELTA_DATETIME_COLUMNS&quot;)).isEmpty()){&#xA;&#x9;String[] deltaColumns = ((String)globalMap.get(&quot;tables.DELTA_DATETIME_COLUMNS&quot;)).split(&quot;\\|&quot;);&#xA;&#x9;&#xA;&#x9;&#xA;&#x9;// System.out.println(SQL_QUERY_SELECT);&#xA;&#x9;&#xA;&#x9;// Construction de la condition SQL&#xA;&#x9;StringBuilder SQL_CONDITION = new StringBuilder();&#xA;&#x9;SQL_CONDITION.append(&quot; AND (&quot;);&#xA;&#x9;&#xA;&#x9;for (int i = 0; i &lt; deltaColumns.length; i++) {&#xA;&#x9;&#xA;&#x9;&#x9;SQL_CONDITION.append(deltaColumns[i])&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;.append(&quot; >= CAST('&quot;)&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;.append(Last_Exec_Value)&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;.append(&quot;' AS datetime2)&quot;);&#xA;&#x9;&#xA;&#x9;&#x9;// Ajout du OR sauf pour la dernière colonne&#xA;&#x9;&#x9;if (i &lt; deltaColumns.length - 1) {&#xA;&#x9;&#x9;&#x9;SQL_CONDITION.append(&quot; OR &quot;);&#xA;&#x9;&#x9;}&#xA;&#x9;}&#xA;&#x9;SQL_CONDITION.append(&quot;)&quot;);&#xA;&#x9;SQL_QUERY_CONDITION = SQL_CONDITION.toString();&#xA;}&#xA;&#xA;&#xA;// Requête final&#xA;String SQL_QUERY = SQL_QUERY_SELECT + SQL_QUERY_CONDITION;&#xA;globalMap.put(&quot;SQL_QUERY&quot;, SQL_QUERY);&#xA;//System.out.println(SQL_QUERY);&#xA;"/>
    <elementParameter field="MEMO_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="LABEL" value="__UNIQUE_NAME__&lt;br>&lt;b>Construction X3 select query&lt;/b>"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJava_1"/>
  </node>
  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="736" posY="448">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_2" show="false"/>
    <elementParameter field="MEMO_JAVA" name="CODE" value="// Récupération de la connexion SageX3&#xA;java.sql.Connection c = (java.sql.Connection) globalMap.get(&quot;conn_tDBConnection_2&quot;);&#xA;&#xA;// Pour MAJ context date&#xA;globalMap.put(&quot;Last_Exec_New_Value&quot;, TalendDate.getCurrentDate());&#xA;&#xA;String SQL_QUERY = (String) globalMap.get(&quot;SQL_QUERY&quot;);&#xA;&#xA;Statement stmt = null;&#xA;ResultSet rs = null;&#xA;BufferedWriter writer = null;&#xA;&#xA;try {&#xA;    stmt = c.createStatement();&#xA;    rs = stmt.executeQuery(SQL_QUERY);&#xA;&#xA;    ResultSetMetaData meta = rs.getMetaData();&#xA;    int columnCount = meta.getColumnCount();&#xA;&#xA;    // Vérifie s'il y a des données&#xA;    if (!rs.next()) {&#xA;        System.out.println(&quot;Aucune donnée à synchro pour la table &quot; &#xA;            + ((String)globalMap.get(&quot;tables.X3_TABLE_NAME&quot;)) + &quot;.&quot;);&#xA;        return;&#xA;    }&#xA;&#xA;    // Construction de la liste des noms de colonnes&#xA;    StringBuilder listColumnBuilder = new StringBuilder();&#xA;    for (int i = 1; i &lt;= columnCount; i++) {&#xA;        listColumnBuilder.append(meta.getColumnLabel(i));&#xA;        if (i &lt; columnCount) {&#xA;            listColumnBuilder.append(&quot;|&quot;);&#xA;        }&#xA;    }&#xA;    globalMap.put(&quot;list_column&quot;, listColumnBuilder.toString());&#xA;&#xA;    // Création du fichier uniquement s'il y a des données&#xA;    writer = new BufferedWriter(&#xA;        new OutputStreamWriter(&#xA;            new GZIPOutputStream(&#xA;                new FileOutputStream(&#xA;                    ((String)globalMap.get(&quot;snowflake_dir&quot;))&#xA;                    + ((String)globalMap.get(&quot;tables.X3_TABLE_NAME&quot;))&#xA;                    + &quot;_export.csv.gz&quot;&#xA;                )&#xA;            ),&#xA;            &quot;UTF-8&quot;&#xA;        )&#xA;    );&#xA;&#xA;    // Traitement des lignes&#xA;    do {&#xA;        StringBuilder row = new StringBuilder();&#xA;&#xA;        for (int i = 1; i &lt;= columnCount; i++) {&#xA;            Object val = rs.getObject(i);&#xA;            int sqlType = meta.getColumnType(i);&#xA;&#xA;            // Gestion  des NULL&#xA;            if (val != null) {&#xA;&#xA;                row.append(&quot;\&quot;&quot;); // début champ&#xA;&#xA;                // Cas des champs binary -->  conversion en hex&#xA;                if (sqlType == Types.BINARY &#xA;                    || sqlType == Types.VARBINARY &#xA;                    || sqlType == Types.LONGVARBINARY) {&#xA;&#xA;                    byte[] bytes = rs.getBytes(i);&#xA;                    StringBuilder hex = new StringBuilder();&#xA;&#xA;                    for (byte b : bytes) {&#xA;                        hex.append(String.format(&quot;%02X&quot;, b));&#xA;                    }&#xA;&#xA;                    row.append(hex.toString());&#xA;&#xA;                } else {&#xA;                    // échappement des guillemets&#xA;                    row.append(val.toString().replace(&quot;\&quot;&quot;, &quot;\&quot;\&quot;&quot;));&#xA;                }&#xA;&#xA;                row.append(&quot;\&quot;&quot;); // fin champ&#xA;            }&#xA;            // Si NULL on n’écrit rien &#xA;&#xA;            // séparateur&#xA;            if (i &lt; columnCount) {&#xA;                row.append(&quot;|&quot;);&#xA;            }&#xA;        }&#xA;&#xA;        writer.write(row.toString());&#xA;        writer.newLine();&#xA;&#xA;    } while (rs.next());&#xA;&#xA;    writer.flush();&#xA;&#xA;} catch (Exception e) {&#xA;    e.printStackTrace();&#xA;} finally {&#xA;    try { if (rs != null) rs.close(); } catch (Exception e) {}&#xA;    try { if (stmt != null) stmt.close(); } catch (Exception e) {}&#xA;    try { if (writer != null) writer.close(); } catch (Exception e) {}&#xA;}"/>
    <elementParameter field="MEMO_IMPORT" name="IMPORT" value="import java.sql.Connection;&#xA;import java.sql.DriverManager;&#xA;import java.sql.Statement;&#xA;import java.sql.ResultSet;&#xA;import java.sql.ResultSetMetaData;&#xA;import java.io.BufferedWriter;&#xA;import java.io.OutputStreamWriter;&#xA;import java.io.FileOutputStream;&#xA;import java.sql.*;&#xA;import java.io.*;&#xA;import java.util.Base64;&#xA;import java.util.zip.GZIPOutputStream;"/>
    <elementParameter field="TEXT" name="LABEL" value="__UNIQUE_NAME__&lt;br>&lt;b>Exec query get data&lt;/b>"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJava_2"/>
  </node>
  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="1248" posY="448">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_3" show="false"/>
    <elementParameter field="MEMO_JAVA" name="CODE" value="String time = TalendDate.formatDate(&quot;yyyy_MM_dd_HHmm_sss&quot;,TalendDate.getCurrentDate());&#xA;&#xA;String list_column = ((String)globalMap.get(&quot;list_column&quot;));&#xA;String SF_TABLE_NAME = ((String)globalMap.get(&quot;tables.SF_TABLE_NAME&quot;));&#xA;String X3_TABLE_NAME = ((String)globalMap.get(&quot;tables.X3_TABLE_NAME&quot;));&#xA;String TEMP_TABLE_name = SF_TABLE_NAME+&quot;_&quot;+time;&#xA;// Scripts de création STAGE et DOSSIER temporaire de travail par table.&#xA;String STAGE = &quot;CREATE TEMPORARY STAGE &quot;+SF_TABLE_NAME+&quot;_tmp&quot;;&#xA;String DOSSIER = &quot;@~/&quot;+SF_TABLE_NAME+&quot;_tmp/MODIFY/&quot;+time;&#xA;&#xA;//Scripts pour insérer les fichiers gzip dans le dossier du stage&#xA;String PUT = &quot;PUT \'file://&quot;+((String)globalMap.get(&quot;snowflake_dir&quot;)).replaceAll(&quot;([/\\\\]{2,}|/\\\\|\\\\/)+&quot;, &quot;/&quot;).replace(&quot;\\&quot;, &quot;/&quot;)+X3_TABLE_NAME+&quot;_export.csv.gz' &quot;+ DOSSIER + &quot; parallel=10 overwrite=true auto_compress=false SOURCE_COMPRESSION=gzip&quot;;&#xA;&#xA;// Permet de lister les fichiers d'un dossier &#xA;String LIST = &quot;LIST &quot;+ DOSSIER;&#xA;&#xA;String TEMP_TABLE = &quot;CREATE TEMPORARY TABLE \&quot;&quot;+TEMP_TABLE_name+&quot;\&quot; LIKE \&quot;&quot;+SF_TABLE_NAME+&quot;\&quot;&quot;;&#xA;&#xA;&#xA;String COPY = &quot;COPY INTO \&quot;&quot;+TEMP_TABLE_name+&quot;\&quot; FROM '&quot;+DOSSIER+&quot;' on_error='CONTINUE' file_format=( TYPE = 'CSV' ENCODING = 'UTF8' COMPRESSION = 'GZIP' FIELD_DELIMITER='|' FIELD_OPTIONALLY_ENCLOSED_BY = '\&quot;'  empty_field_as_null=true)&quot;;&#xA;&#xA;&#xA;String MERGE_DEBUT_SCRIPTS = &quot;MERGE INTO &quot;+ SF_TABLE_NAME+&quot; T USING &quot; + TEMP_TABLE_name+&quot; S&quot;;&#xA;String[] keyColumns = ((String)globalMap.get(&quot;tables.PRIMARY_KEY_COLUMNS&quot;)).split(&quot;\\|&quot;);&#xA;String[] column_table = list_column.split(&quot;\\|&quot;);&#xA;&#xA;//-------------------------------------------------------------------------------------------&#xA;// Construction de la jointure de clé &#xA;StringBuilder JOIN_KEYS = new StringBuilder();&#xA;JOIN_KEYS.append(&quot; ON &quot; );&#xA;&#xA;for (int i = 0; i &lt; keyColumns.length; i++) {&#xA;&#xA;    JOIN_KEYS.append(&quot;T.&quot;+keyColumns[i]+&quot; = S.&quot;+keyColumns[i]);&#xA;&#x9;&#xA;    // Ajout du AND sauf pour la dernière colonne&#xA;    if (i &lt; keyColumns.length - 1) {&#xA;        JOIN_KEYS.append(&quot; AND &quot;);&#xA;    }&#xA;}&#xA;//--------------------------------------------------------------------------------------------&#xA;//-------------------------------------------------------------------------------------------&#xA;// Construction de la partie update  // Construction jointure sur date  &#xA;StringBuilder UPDATE_PARTIE = new StringBuilder();&#xA;&#xA;if(!Relational.ISNULL(((String)globalMap.get(&quot;tables.DELTA_DATETIME_COLUMNS&quot;))) &amp;&amp; !((String)globalMap.get(&quot;tables.DELTA_DATETIME_COLUMNS&quot;)).isEmpty()){&#xA;&#x9;String[] deltaColumns = ((String)globalMap.get(&quot;tables.DELTA_DATETIME_COLUMNS&quot;)).split(&quot;\\|&quot;);&#xA;&#x9;UPDATE_PARTIE.append(&quot; WHEN MATCHED AND ( &quot; );&#xA;&#x9;for (int i = 0; i &lt; deltaColumns.length; i++) {&#xA;&#xA;    &#x9;UPDATE_PARTIE.append(&quot;T.&quot;+deltaColumns[i]+&quot; IS DISTINCT FROM S.&quot;+deltaColumns[i]);&#xA;&#x9;&#xA;    &#x9;// Ajout du OR sauf pour la dernière colonne&#xA;    &#x9;if (i &lt; deltaColumns.length - 1) {&#xA;        &#x9;UPDATE_PARTIE.append(&quot; OR &quot;);&#xA;    &#x9;}&#xA;&#x9;}&#xA;&#x9;&#x9;UPDATE_PARTIE.append(&quot; )&quot; );&#xA;}&#xA;&#xA;//--------------------------------------------------------------------------------------------&#xA;&#xA;&#xA;UPDATE_PARTIE.append(&quot; THEN UPDATE SET &quot; );&#xA;&#xA;for (int i = 0; i &lt; column_table.length; i++) {&#xA;&#xA;    UPDATE_PARTIE.append(&quot;T.&quot;+column_table[i]+&quot; = S.&quot;+column_table[i]);&#xA;&#x9;&#xA;    // Ajout d'une virgule sauf pour la dernière colonne&#xA;    if (i &lt; column_table.length - 1) {&#xA;        UPDATE_PARTIE.append(&quot;, &quot;);&#xA;    }&#xA;}&#xA;&#xA;//-------------------------------------------------------------------------------------------&#xA;&#xA;// Construction de la partie INSERT &#xA;StringBuilder INSERT_PARTIE = new StringBuilder();&#xA;INSERT_PARTIE.append(&quot; WHEN NOT MATCHED THEN INSERT( &quot; );&#xA;&#xA;for (int i = 0; i &lt; column_table.length; i++) {&#xA;&#xA;    INSERT_PARTIE.append(column_table[i]);&#xA;&#x9;&#xA;    // Ajout d'une virgule sauf pour la dernière colonne&#xA;    if (i &lt; column_table.length - 1) {&#xA;        INSERT_PARTIE.append(&quot;, &quot;);&#xA;    }&#xA;}&#xA;INSERT_PARTIE.append(&quot; )&quot;);&#xA;INSERT_PARTIE.append(&quot; VALUES( &quot; );&#xA;&#xA;for (int i = 0; i &lt; column_table.length; i++) {&#xA;&#xA;    INSERT_PARTIE.append(column_table[i]);&#xA;&#x9;&#xA;    // Ajout d'une virgule sauf pour la dernière colonne&#xA;    if (i &lt; column_table.length - 1) {&#xA;        INSERT_PARTIE.append(&quot;, &quot;);&#xA;    }&#xA;}&#xA;INSERT_PARTIE.append(&quot; )&quot;);&#xA;&#xA;//System.out.println(MERGE_DEBUT_SCRIPTS +JOIN_KEYS.toString()+ UPDATE_PARTIE.toString() + INSERT_PARTIE.toString() );&#xA;&#xA;String MERGE = MERGE_DEBUT_SCRIPTS +JOIN_KEYS.toString()+ UPDATE_PARTIE.toString() + INSERT_PARTIE.toString() ;&#xA;//-------------------------------------------------------------------------------------------&#xA;&#xA;&#xA;/*&#xA;System.out.println(PUT);&#xA;System.out.println(TEMP_TABLE);&#xA;System.out.println(COPY);&#xA;*/&#xA;System.out.println(MERGE);&#xA;&#xA;&#xA;&#xA;globalMap.put(&quot;STAGE&quot;, STAGE);&#xA;globalMap.put(&quot;PUT&quot;, PUT);&#xA;globalMap.put(&quot;TEMP_TABLE&quot;, TEMP_TABLE);&#xA;globalMap.put(&quot;TEMP_TABLE_name&quot;, TEMP_TABLE_name);&#xA;globalMap.put(&quot;COPY&quot;, COPY);&#xA;globalMap.put(&quot;MERGE&quot;, MERGE);&#xA;globalMap.put(&quot;LIST&quot;, LIST);&#xA;&#xA;&#xA;&#xA;"/>
