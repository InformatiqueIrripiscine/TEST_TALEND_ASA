    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT Y1.ITMREF_0, SUM(Y1.QTYSTK_0) AS SUM_QTYSTK_0&#xD;&#xA;FROM&#x9;\&quot;&quot;+context.Sage_X3_Schema+&quot;\&quot;.YVITVSTCK Y1&#xD;&#xA;WHERE Y1.ITMREF_0 IN&#xD;&#xA;&#x9;(SELECT DISTINCT Y2.ITMREF_0&#xD;&#xA;&#x9;FROM \&quot;&quot;+context.Sage_X3_Schema+&quot;\&quot;.YVITVSTCK Y2&#xD;&#xA;&#x9;WHERE (Y2.LAST_UPDATE_DATE_0 > CAST('&quot; + context.Last_Exec_Date_Stock + &quot;' as DATE)&#xD;&#xA;&#x9;&#x9;))&#xD;&#xA;GROUP BY Y1.ITMREF_0&quot;&#xD;&#xA;&#xD;&#xA;/*&#xD;&#xA;&quot;SELECT \&quot;&quot;+context.Sage_X3_Schema+&quot;\&quot;.YVITVSTCK.ITMREF_0,&#xA;&#x9;&#x9;\&quot;&quot;+context.Sage_X3_Schema+&quot;\&quot;.YVITVSTCK.QTYSTK_0,&#xA;&#x9;&#x9;\&quot;&quot;+context.Sage_X3_Schema+&quot;\&quot;.YVITVSTCK.STOFCY_0,&#xA;&#x9;&#x9;\&quot;&quot;+context.Sage_X3_Schema+&quot;\&quot;.YVITVSTCK.UPDDAT_0,&#xA;&#x9;&#x9;\&quot;&quot;+context.Sage_X3_Schema+&quot;\&quot;.YVITVSTCK.UPDTIM_0,&#xA;&#x9;&#x9;\&quot;&quot;+context.Sage_X3_Schema+&quot;\&quot;.YVITVSTCK.UPDUSR_0&quot;&#xA;+&quot;&#xA;FROM&#x9;\&quot;&quot;+context.Sage_X3_Schema+&quot;\&quot;.YVITVSTCK&quot;&#xD;&#xA;*/"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
