    <elementParameter field="MEMO_JAVA" name="CODE" value="String token_attachement = ((String)globalMap.get(&quot;token_attachement&quot;));&#xA;&#xA;String jsonString = &quot;{&quot;&#xA;    + &quot;\&quot;ticket\&quot;: {&quot;&#xA;    + &quot;\&quot;subject\&quot;: \&quot;&quot; + context.subject + &quot;\&quot;,&quot;&#xA;    + &quot;\&quot;comment\&quot;: {&quot;&#xA;    + &quot;\&quot;body\&quot;: \&quot;&quot; + context.message + &quot;\&quot;&quot;&#xA;    + (token_attachement != null &amp;&amp; !token_attachement.isEmpty() ? &quot;, \&quot;uploads\&quot;: [&quot; + token_attachement + &quot;]&quot; : &quot;&quot;) // Ajout d'une pièce jointe si il y en a &#xA;    + &quot;},&quot;&#xA;    + &quot;\&quot;requester\&quot;: {&quot;&#xA;    + &quot;\&quot;name\&quot;: \&quot;ETL TALEND\&quot;,&quot;&#xA;    + &quot;\&quot;email\&quot;: \&quot;ETL_TALEND@IRRI.COM\&quot;&quot;  // Ajout d'un email pour ne pas créer un nouveau client à chaque appel API&#xA;    + &quot;},&quot;&#xA;    + &quot;\&quot;type\&quot;: \&quot;&quot;+context.type_ticket+&quot;\&quot;,&quot;&#xA;    + &quot;\&quot;brand_id\&quot;: &quot; + context.Zendesk_brand_irrijardin_centrale_id + &quot;,&quot;&#xA;    + &quot;\&quot;group_id\&quot;: &quot; + context.Zendesk_group + &quot;,&quot;&#xA;    + &quot;\&quot;ticket_form_id\&quot;: &quot; + context.Zendesk_formulaire_id + &quot;,&quot;&#xA;    + &quot;\&quot;tags\&quot;: [\&quot;exploitation\&quot;],&quot;  // Ajout du tag ou marqueur&#xA;    + &quot;\&quot;custom_fields\&quot;: [&quot;&#xA;    + &quot;  {\&quot;id\&quot;: 4436713594257, \&quot;value\&quot;: \&quot;&quot; + context.Exploitation_impactée + &quot;\&quot;}&quot;&#xA;    + &quot;]&quot;&#xA;    + &quot;}&quot;&#xA;    + &quot;}&quot;;&#xA;&#xA;System.out.println(jsonString);&#xA;&#xA;globalMap.put(&quot;jsonString&quot;, jsonString);&#xA;"/>
    <elementParameter field="MEMO_IMPORT" name="IMPORT" value="//import java.util.List;"/>
